---
import { getCollection } from 'astro:content';
import '../styles/global.css';

// Mengambil semua data dari koleksi 'projects'
const allProjects = await getCollection('projects');
---

<html lang="id">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Portofolio Saya</title>
	</head>
	<body class="bg-slate-900 text-slate-100 min-h-screen p-8">
		<main class="max-w-4xl mx-auto">
			<h1 class="text-4xl font-bold mb-2 text-teal-400">Halo, Saya Developer</h1>
			<p class="text-slate-400 mb-8">Selamat datang di website portofolio statis saya yang super ringan.</p>

			<h2 class="text-2xl font-semibold mb-4 border-b border-slate-700 pb-2">Proyek Terbaru</h2>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{allProjects.map(project => (
					<div class="bg-slate-800 p-6 rounded-xl border border-slate-700 shadow-lg hover:border-teal-500 transition-colors">
						<h3 class="text-xl font-bold mb-2 text-slate-100">{project.data.title}</h3>
						<p class="text-slate-400 text-sm mb-4">{project.data.description}</p>
						<div class="flex flex-wrap gap-2">
							{project.data.tags.map(tag => (
								<span class="bg-slate-900 text-teal-400 text-xs px-2.5 py-1 rounded-md border border-slate-700">
									{tag}
								</span>
							))}
						</div>
					</div>
				))}
			</div>
		</main>
	</body>
</html>